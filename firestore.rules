rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users: Solo lectura (públicos)
    match /users/{userId} {
      allow read: if true;  // Todos pueden leer profiles
      allow write: if request.auth.uid == userId;  // Solo owner puede escribir

      // Subcolección de likes dados
      match /likesGiven/{likeId} {
        allow read: if request.auth != null; // Solo usuarios logueados pueden ver likes de otros
        allow write: if request.auth.uid == userId; // Solo el dueño puede dar/quitar likes
      }
    }
    
    // Conversaciones: Acceso para participantes
    match /conversaciones/{conversationId} {
      allow read, write: if true;  // Simplificado para tu app
      
      // Mensajes dentro de conversaciones
      match /mensajes/{messageId} {
        allow read, write: if true;  // Simplificado
      }
    }
  }
}
